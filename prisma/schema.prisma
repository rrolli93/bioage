// BioAge - Biological Age Tracker
// Schema for PostgreSQL (production) via Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ProtocolEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  startDate DateTime
  category  String
  compound  String
  dose      String
  route     String
  source    String?
  notes     String?
  active    Boolean  @default(true)
}

model BioAgeEntry {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  date             DateTime
  chronoAge        Float
  phenoAge         Float
  delta            Float
  metabolicAge     Float?
  immuneAge        Float?
  inflammatoryAge  Float?
  hematologicalAge Float?
  rawInputs        Json     // Native JSON in PostgreSQL
}
